// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MEMBER
}

enum DeviceType {
  DESKTOP
  MOBILE
  TABLET
  BOT
  UNKNOWN
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

model User {
  id         String   @id @default(cuid())
  firebaseId String   @unique @map("firebase_id")
  email      String   @unique
  firstName  String?  @map("first_name")
  lastName   String?  @map("last_name")
  role       UserRole @default(MEMBER)

  // membership OrganizationMember?

  // CynoGuard Specifics
  isActive  Boolean   @default(true) @map("is_active")
  lastLogin DateTime? @map("last_login")

  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  organizationMembers OrganizationMember[]

  @@map("users") // The table in AWS RDS will still be called "users"
}

model Organization {
  id             String   @id @default(uuid())
  name           String   @unique
  industry       String?
  businessType   String?  @map("business_type")
  primaryUses    String[] @map("primary_uses")
  teamSize       String?  @map("team_size")
  discoverSource String?  @map("discover_source")
  offerCode      String?  @map("offer_code")
  isOnboarded    Boolean  @default(false) @map("is_onboarded")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  memebers OrganizationMember[]
  projects Project[]

  @@map("organizations")
}

model Project {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  name           String
  status         String       @default("active")
  createdAt      DateTime     @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id])
  apiKeys        ApiKey[]
  detections     Detection[]
  industry       String?      @map("industry")
  environment    String       @map("environment") // e.g. production, staging, development
  primary_domain String       @map("primary_domain")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@unique([name, organizationId]) // Ensure project names are unique within an organization
  @@map("projects")
}

model ApiKey {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  keyHash    String   @unique @map("key_hash")
  name       String
  scopes     String?
  status     String   @default("pending")
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  //relation
  project Project @relation(fields: [projectId], references: [id])
  rule ApiKeyRule?


  @@map("api_keys")
}


model Detection {
  id        String @id @default(uuid())
  projectId String @map("project_id")

  // ── Visitor Identity ──────────────────────
  sessionId String? @map("session_id")

  // ── Network ───────────────────────────────
  ipAddress   String  @map("ip_address")
  countryCode String? @map("country_code")
  city        String?

  // ── Device & UA ───────────────────────────
  userAgent  String     @map("user_agent")
  deviceType DeviceType @default(UNKNOWN) @map("device_type")
  isHeadless Boolean    @default(false) @map("is_headless")

  // ── Assessment ────────────────────────────
  score     Int
  riskLevel RiskLevel @map("risk_level")
  action    String
  isHuman   Boolean   @map("is_human")

  // ── Challenge Summary (denormalized) ──────
  challengeCount  Int     @default(0) @map("challenge_count")
  challengeSolved Boolean @default(false) @map("challenge_solved")

  // ── Timing ────────────────────────────────
  timeToSolve Int @default(0) @map("time_to_solve")

  // ── Raw Signals ───────────────────────────
  signals Json

  createdAt DateTime @default(now()) @map("created_at")

  // ── Relations ─────────────────────────────
  project           Project            @relation(fields: [projectId], references: [id])
  challengeAttempts ChallengeAttempt[]

  // ── Indexes ───────────────────────────────
  @@index([projectId, createdAt])
  @@index([projectId, action])
  @@index([projectId, countryCode])
  @@index([projectId, isHuman])
  @@index([sessionId])
  @@index([ipAddress])
  @@map("detections")
}

model ChallengeAttempt {
  id          String   @id @default(uuid())
  detectionId String   @map("detection_id")
  challengeId String   @map("challenge_id")

  issuedAt    DateTime  @default(now()) @map("issued_at")
  answeredAt  DateTime? @map("answered_at")
  success     Boolean
  timeToSolve Int?      @map("time_to_solve")

  detection Detection     @relation(fields: [detectionId], references: [id])
  challenge ChallengeBank @relation(fields: [challengeId], references: [id])

  @@index([detectionId])
  @@index([challengeId])
  @@map("challenge_attempts")
}

model ChallengeBank {
  id              String  @id @default(uuid())
  value           String  @unique
  successCount    Int     @default(0) @map("success_count")
  failCount       Int     @default(0) @map("fail_count")
  isActive        Boolean @default(true) @map("is_active")
  difficultyLevel Int     @default(0) @map("difficulty_level")

  attempts ChallengeAttempt[]

  @@map("challenge_bank")
}


model OrganizationMember {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  userId         String @map("user_id")
  role           String @default("OWNER")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  // This ensures a user can't be added to the same org twice
  @@unique([userId, organizationId])
  @@map("organization_members")
}

model ApiKeyRule {
  id          String   @id @default(uuid())
  apiKeyId    String   @unique @map("api_key_id")
  strictness  String   @default("balanced") // "passive" | "balanced" | "aggressive"
  persistence Int      @default(48)          // hours
  signals     Json     @default("{}")        // { headless: true, hardwareMismatch: true, mouseAnalysis: true }
  whitelist   Json     @default("[]")        // [{ name, type, value }]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id])

  @@map("api_key_rules")
}

