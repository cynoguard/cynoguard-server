// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init;

generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MEMBER
}

enum DeviceType {
  DESKTOP
  MOBILE
  TABLET
  BOT
  UNKNOWN
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum Platform {
  X
}

enum MentionStatus {
  NEW
  VIEWED
  DISMISSED
  ARCHIVED
}

enum ScanStatus {
  SUCCESS
  FAILED
  PARTIAL
}

enum Sentiment {
  POSITIVE
  NEGATIVE
  NEUTRAL
}

enum WatchDomainStatus {
  ACTIVE
  INACTIVE
}

enum TldStrategy {
  SAME_TLD_ONLY
  ALLOWLIST
  MIXED
}

enum CandidateSource {
  ALGO
  GEMINI
  MANUAL
}

enum AlertType {
  SUSPICIOUS_DOMAIN
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model User {
  id         String   @id @default(cuid())
  firebaseId String   @unique @map("firebase_id")
  email      String   @unique
  firstName  String?  @map("first_name")
  lastName   String?  @map("last_name")
  role       UserRole @default(MEMBER)
  isActive   Boolean  @default(true) @map("is_active")
  lastLogin  DateTime? @map("last_login")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  organizationMembers OrganizationMember[]

  @@map("users")
}

model Organization {
  id             String   @id @default(uuid())
  name           String   @unique
  industry       String?
  businessType   String?  @map("business_type")
  primaryUses    String[] @map("primary_uses")
  teamSize       String?  @map("team_size")
  discoverSource String?  @map("discover_source")
  offerCode      String?  @map("offer_code")
  isOnboarded    Boolean  @default(false) @map("is_onboarded")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  members  OrganizationMember[]
  projects Project[]

  @@map("organizations")
}

model Project {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  status         String   @default("active")
  industry       String?
  environment    String
  primaryDomain  String   @map("primary_domain")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization       @relation(fields: [organizationId], references: [id])
  apiKeys      ApiKey[]
  detections   Detection[]

  // Social Monitoring — CynoGuard's shared token, no per-project credentials
  keywords     MonitoringKeyword[]
  mentions     BrandMention[]
  scanLogs     ScanLog[]
  watchlistEntries WatchlistEntry[]

  @@unique([name, organizationId])
  @@map("projects")
}

// ─── Bot Detection ────────────────────────────────────────────────────────────

model ApiKey {
  id         String    @id @default(uuid())
  projectId  String    @map("project_id")
  keyHash    String    @unique @map("key_hash")
  name       String
  scopes     String?
  status     String    @default("pending")
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  project Project    @relation(fields: [projectId], references: [id])
  rule    ApiKeyRule?

  @@map("api_keys")
}

model Detection {
  id          String     @id @default(uuid())
  projectId   String     @map("project_id")
  sessionId   String?    @map("session_id")
  ipAddress   String     @map("ip_address")
  countryCode String?    @map("country_code")
  city        String?
  userAgent   String     @map("user_agent")
  deviceType  DeviceType @default(UNKNOWN) @map("device_type")
  isHeadless  Boolean    @default(false) @map("is_headless")
  score       Int
  riskLevel   RiskLevel  @map("risk_level")
  action      String
  isHuman     Boolean    @map("is_human")
  challengeCount  Int    @default(0) @map("challenge_count")
  challengeSolved Boolean @default(false) @map("challenge_solved")
  timeToSolve Int        @default(0) @map("time_to_solve")
  signals     Json
  createdAt   DateTime   @default(now()) @map("created_at")

  project           Project            @relation(fields: [projectId], references: [id])
  challengeAttempts ChallengeAttempt[]

  @@index([projectId, createdAt])
  @@index([projectId, action])
  @@index([projectId, countryCode])
  @@index([projectId, isHuman])
  @@index([sessionId])
  @@index([ipAddress])
  @@map("detections")
}

model ChallengeAttempt {
  id          String    @id @default(uuid())
  detectionId String    @map("detection_id")
  challengeId String    @map("challenge_id")
  issuedAt    DateTime  @default(now()) @map("issued_at")
  answeredAt  DateTime? @map("answered_at")
  success     Boolean
  timeToSolve Int?      @map("time_to_solve")

  detection Detection     @relation(fields: [detectionId], references: [id])
  challenge ChallengeBank @relation(fields: [challengeId], references: [id])

  @@index([detectionId])
  @@index([challengeId])
  @@map("challenge_attempts")
}

model ChallengeBank {
  id              String  @id @default(uuid())
  value           String  @unique
  successCount    Int     @default(0) @map("success_count")
  failCount       Int     @default(0) @map("fail_count")
  isActive        Boolean @default(true) @map("is_active")
  difficultyLevel Int     @default(0) @map("difficulty_level")

  attempts ChallengeAttempt[]

  @@map("challenge_bank")
}

model OrganizationMember {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  userId         String @map("user_id")
  role           String @default("OWNER")

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([userId, organizationId])
  @@map("organization_members")
}

model ApiKeyRule {
  id         String   @id @default(uuid())
  apiKeyId   String   @unique @map("api_key_id")
  strictness String   @default("balanced")
  persistence Int     @default(48)
  signals    Json     @default("{}")
  whitelist  Json     @default("[]")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id])

  @@map("api_key_rules")
}

// ─── Social Monitoring ────────────────────────────────────────────────────────
// CynoGuard owns a single X_BEARER_TOKEN from env.
// No per-project credentials — SocialHandler model is removed.

model MonitoringKeyword {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  keyword   String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, keyword])
  @@index([projectId])
  @@map("monitoring_keywords")
}

model BrandMention {
  id             String        @id @default(uuid())
  projectId      String        @map("project_id")
  platform       Platform      @default(X)
  externalId     String        @map("external_id")
  content        String
  authorUsername String        @map("author_username")
  authorId       String        @map("author_id")
  tweetUrl       String?       @map("tweet_url")
  likeCount      Int           @default(0) @map("like_count")
  retweetCount   Int           @default(0) @map("retweet_count")
  riskScore      Int           @default(0) @map("risk_score")
  riskLevel      RiskLevel     @default(LOW) @map("risk_level")
  riskFlags      String[]      @map("risk_flags")
  status         MentionStatus @default(NEW)
  sentiment      Sentiment     @default(NEUTRAL)
  matchedKeyword String?       @map("matched_keyword")
  publishedAt    DateTime?     @map("published_at")
  scannedAt      DateTime      @default(now()) @map("scanned_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, externalId])
  @@index([projectId, riskLevel])
  @@index([projectId, status])
  @@index([projectId, sentiment])
  @@index([projectId, matchedKeyword])
  @@map("brand_mentions")
}

model ScanLog {
  id            String     @id @default(uuid())
  projectId     String     @map("project_id")
  platform      Platform   @default(X)
  scanStatus    ScanStatus @default(SUCCESS)
  mentionsFound Int        @default(0) @map("mentions_found")
  highRiskCount Int        @default(0) @map("high_risk_count")
  errorMessage  String?    @map("error_message")
  scannedAt     DateTime   @default(now()) @map("scanned_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("scan_logs")
}

// ─── Domain Monitoring ───────────────────────────────────────────────────────

model WatchDomain {
  id                  String            @id @default(uuid())
  tenantId            String            @map("tenant_id")
  userId              String            @map("user_id")
  domain              String
  label               String?
  status              WatchDomainStatus @default(ACTIVE)
  tldStrategy         TldStrategy       @default(MIXED) @map("tld_strategy")
  tldAllowlist        String[]          @default([]) @map("tld_allowlist")
  tldSuspicious       String[]          @default([]) @map("tld_suspicious")
  similarityThreshold Float?            @map("similarity_threshold")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  candidates CandidateDomain[]
  alerts     Alert[]

  @@unique([tenantId, domain])
  @@index([tenantId, status])
  @@map("watch_domains")
}

model WatchlistEntry {
  id                     String    @id @default(uuid())
  projectId              String    @map("project_id")
  officialDomainRaw      String    @map("official_domain_raw")
  officialDomainNormalized String  @map("official_domain_normalized")
  label                  String?
  active                 Boolean   @default(true)
  intervalHours          Int       @default(24) @map("interval_hours")
  candidateCount         Int       @default(100) @map("candidate_count")
  similarityThreshold    Float     @default(0.8) @map("similarity_threshold")
  tldStrategy            TldStrategy @default(SAME_TLD_ONLY) @map("tld_strategy")
  tldAllowlist           String[]  @default([]) @map("tld_allowlist")
  tldSuspicious          String[]  @default([]) @map("tld_suspicious")
  lastScanAt             DateTime? @map("last_scan_at")
  lastScanStatus         String?   @map("last_scan_status")
  nextRunAt              DateTime? @map("next_run_at")
  suspiciousCount        Int       @default(0) @map("suspicious_count")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  candidates   CandidateDomain[]
  domainScans  DomainScanLog[]

  @@unique([projectId, officialDomainNormalized])
  @@index([projectId, active])
  @@index([nextRunAt])
  @@map("watchlist_entries")
}

model CandidateDomain {
  id               String           @id @default(uuid())
  watchDomainId    String?          @map("watch_domain_id")
  watchlistEntryId String?          @map("watchlist_entry_id")
  domain           String
  tld              String
  source           CandidateSource
  similarityScore  Float            @map("similarity_score")
  isActive         Boolean          @default(true) @map("is_active")
  rdapRegistered   Boolean?         @map("rdap_registered")
  rdapCheckedAt    DateTime?        @map("rdap_checked_at")
  rdapStatus       String[]         @default([]) @map("rdap_status")
  rdapRaw          Json?            @map("rdap_raw")
  riskLevel        RiskLevel        @default(LOW) @map("risk_level")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  watchDomain    WatchDomain?   @relation(fields: [watchDomainId], references: [id], onDelete: Cascade)
  watchlistEntry WatchlistEntry? @relation(fields: [watchlistEntryId], references: [id], onDelete: Cascade)
  alerts         Alert[]

  @@unique([watchDomainId, domain])
  @@unique([watchlistEntryId, domain])
  @@index([watchDomainId])
  @@index([watchlistEntryId])
  @@index([domain])
  @@index([riskLevel])
  @@map("candidate_domains")
}

model DomainScanLog {
  id               String    @id @default(uuid())
  watchlistEntryId String    @map("watchlist_entry_id")
  scannedAt        DateTime  @default(now()) @map("scanned_at")
  status           String?   @map("status")
  summary          Json?     @map("summary")

  watchlistEntry WatchlistEntry @relation(fields: [watchlistEntryId], references: [id], onDelete: Cascade)

  @@index([watchlistEntryId, scannedAt])
  @@map("domain_scan_logs")
}

model Alert {
  id                String        @id @default(uuid())
  tenantId          String        @map("tenant_id")
  userId            String        @map("user_id")
  watchDomainId     String        @map("watch_domain_id")
  candidateDomainId String        @map("candidate_domain_id")
  type              AlertType
  severity          AlertSeverity
  message           String
  isRead            Boolean       @default(false) @map("is_read")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  watchDomain     WatchDomain     @relation(fields: [watchDomainId], references: [id], onDelete: Cascade)
  candidateDomain CandidateDomain @relation(fields: [candidateDomainId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, isRead])
  @@index([watchDomainId, createdAt])
  @@index([candidateDomainId])
  @@map("alerts")
}