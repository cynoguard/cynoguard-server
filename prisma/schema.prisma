// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MEMBER
}

model User {
  id          String   @id @default(cuid())
  firebaseId  String   @unique @map("firebase_id")
  email       String   @unique
  firstName   String?  @map("first_name")
  lastName    String?  @map("last_name")
  role        UserRole @default(MEMBER)
  isOnboarded Boolean  @default(false) @map("is_onboarded")

  // membership OrganizationMember?

  // CynoGuard Specifics
  isActive  Boolean   @default(true) @map("is_active")
  lastLogin DateTime? @map("last_login")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organizations OrganizationMember[]

  @@map("users") // The table in AWS RDS will still be called "users"
}

model Organization {
  id             String   @id @default(uuid())
  name           String
  industry       String?
  discoverSource String?  @map("discover_source")
  offerCode      String?  @map("offer_code")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  members  OrganizationMember[]
  projects Project[]

  @@map("organizations")
}

model Project {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  name           String
  status         String       @default("active")
  createdAt      DateTime     @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id])
  apiKeys        ApiKey[]
  detections     Detection[]
  mentions       Mention[]
  keywords       Keyword[]
  alerts         Alert[]

  @@map("projects")
}

model ApiKey {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  keyHash    String   @unique @map("key_hash")
  name       String
  scopes     String
  status     String
  lastUsedAt DateTime @map("last_used_at")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @map("created_at")

  //relation
  project Project @relation(fields: [projectId], references: [id])

  @@map("api_keys")
}

model Detection {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  ipAddress String   @map("ip_address")
  score     Int
  action    String
  signals   Json
  isHuman   Boolean  @map("is_human")
  createdAt DateTime @map("created_at")
  //relation
  project   Project  @relation(fields: [projectId], references: [id])

  @@map("detections")
}

model OrganizationMember {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  userId         String @unique @map("user_id")
  role           String @default("OWNER")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId])
  @@map("organization_members")
}

enum Platform {
  X
}

model Mention {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  externalId String   @map("external_id") // Reddit post ID / Tweet ID
  platform   Platform
  author     String?
  content    String
  sentiment  String? // POSITIVE / NEGATIVE / NEUTRAL
  keyword    String
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id])
  alerts  Alert[]

  @@unique([platform, externalId])
  @@map("mentions")
}

model Keyword {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  value     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, value])
  @@map("keywords")
}

model Alert {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  mentionId String   @map("mention_id")
  type      String
  severity  String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
  mention Mention @relation(fields: [mentionId], references: [id])

  @@map("alerts")
}
