// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MEMBER
}

model User {
  id         String   @id @default(cuid())
  firebaseId String   @unique @map("firebase_id")
  email      String   @unique
  firstName  String?  @map("first_name")
  lastName   String?  @map("last_name")
  role       UserRole @default(MEMBER)

  // membership OrganizationMember?

  // CynoGuard Specifics
  isActive  Boolean   @default(true) @map("is_active")
  lastLogin DateTime? @map("last_login")

  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  organizationMembers OrganizationMember[]

  @@map("users") // The table in AWS RDS will still be called "users"
}

model Organization {
  id             String   @id @default(uuid())
  name           String   @unique
  industry       String?
  businessType   String?  @map("business_type")
  primaryUses    String[] @map("primary_uses")
  teamSize       String?  @map("team_size")
  discoverSource String?  @map("discover_source")
  offerCode      String?  @map("offer_code")
  isOnboarded    Boolean  @default(false) @map("is_onboarded")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  memebers OrganizationMember[]
  projects Project[]

  @@map("organizations")
}

model Project {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  name           String
  status         String       @default("active")
  createdAt      DateTime     @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id])
  apiKeys        ApiKey[]
  detections     Detection[]
  industry       String?      @map("industry")
  environment    String       @map("environment") // e.g. production, staging, development
  primary_domain String       @map("primary_domain")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@unique([name, organizationId]) // Ensure project names are unique within an organization
  @@map("projects")
}

model ApiKey {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  keyHash    String   @unique @map("key_hash")
  name       String
  scopes     String
  status     String
  lastUsedAt DateTime @map("last_used_at")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @map("created_at")

  //relation
  project Project @relation(fields: [projectId], references: [id])

  @@map("api_keys")
}

model Detection {
  id               String   @id @default(uuid())
  projectId        String   @map("project_id")
  challengeHistory String[] @map("challenge_history")
  ipAddress        String   @map("ip_address")
  score            Int
  action           String
  signals          Json
  isHuman          Boolean  @map("is_human")
  createdAt        DateTime @default(now()) @map("created_at")
  timeToSolve      Int      @map("time_to_solve") // all time data store base as millisecond

  //relations
  project Project @relation(fields: [projectId], references: [id])

  @@map("detections")
}

model OrganizationMember {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  userId         String @map("user_id")
  role           String @default("OWNER")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  // This ensures a user can't be added to the same org twice
  @@unique([userId, organizationId])
  @@map("organization_members")
}

model ChallengeBank {
  id              String  @id @default(uuid())
  value           String  @unique
  successCount    Int     @default(0) @map("success_count")
  failCount       Int     @default(0) @map("fail_count")
  isActive        Boolean @default(true) @map("is_active")
  // 1: Easy (Short sentences)
  // 2: Medium (Standard)
  // 3: Hard (Complex logic/punctuation)
  difficultyLevel Int     @default(0) @map("difficulty_level")

  @@map("challenge_bank")
}
