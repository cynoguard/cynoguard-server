// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_PROD_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MEMBER
}

enum DeviceType {
  DESKTOP
  MOBILE
  TABLET
  BOT
  UNKNOWN
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Platform {
  X
}

enum MentionStatus {
  NEW
  VIEWED
  DISMISSED
  ARCHIVED
}

enum ScanStatus {
  SUCCESS
  FAILED
  PARTIAL
}

enum Sentiment {
  POSITIVE
  NEGATIVE
  NEUTRAL
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model User {
  id         String   @id @default(cuid())
  firebaseId String   @unique @map("firebase_id")
  email      String   @unique
  firstName  String?  @map("first_name")
  lastName   String?  @map("last_name")
  role       UserRole @default(MEMBER)
  isActive   Boolean  @default(true) @map("is_active")
  lastLogin  DateTime? @map("last_login")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  organizationMembers OrganizationMember[]

  @@map("users")
}

model Organization {
  id             String   @id @default(uuid())
  name           String   @unique
  industry       String?
  businessType   String?  @map("business_type")
  primaryUses    String[] @map("primary_uses")
  teamSize       String?  @map("team_size")
  discoverSource String?  @map("discover_source")
  offerCode      String?  @map("offer_code")
  isOnboarded    Boolean  @default(false) @map("is_onboarded")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  members  OrganizationMember[]
  projects Project[]

  @@map("organizations")
}

model Project {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  status         String   @default("active")
  industry       String?
  environment    String
  primaryDomain  String   @map("primary_domain")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization       @relation(fields: [organizationId], references: [id])
  apiKeys      ApiKey[]
  detections   Detection[]

  // Social Monitoring — CynoGuard's shared token, no per-project credentials
  keywords     MonitoringKeyword[]
  mentions     BrandMention[]
  scanLogs     ScanLog[]

  @@unique([name, organizationId])
  @@map("projects")
  watchlistEntries WatchlistEntry[]
}

// ─── Bot Detection ────────────────────────────────────────────────────────────

model ApiKey {
  id         String    @id @default(uuid())
  projectId  String    @map("project_id")
  keyHash    String    @unique @map("key_hash")
  name       String
  scopes     String?
  status     String    @default("pending")
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  connectionVerified Boolean @default(false) @map("connection_verified")
  project Project    @relation(fields: [projectId], references: [id])
  rule    ApiKeyRule?

  @@map("api_keys")
}

model Detection {
  id          String     @id @default(uuid())
  projectId   String     @map("project_id")
  sessionId   String?    @map("session_id")
  ipAddress   String     @map("ip_address")
  countryCode String?    @map("country_code")
  city        String?
  userAgent   String     @map("user_agent")
  deviceType  DeviceType @default(UNKNOWN) @map("device_type")
  isHeadless  Boolean    @default(false) @map("is_headless")
  score       Int
  riskLevel   RiskLevel  @map("risk_level")
  action      String
  isHuman     Boolean    @map("is_human")
  challengeCount  Int    @default(0) @map("challenge_count")
  challengeSolved Boolean @default(false) @map("challenge_solved")
  timeToSolve Int        @default(0) @map("time_to_solve")
  signals     Json
  createdAt   DateTime   @default(now()) @map("created_at")

  project           Project            @relation(fields: [projectId], references: [id])
  challengeAttempts ChallengeAttempt[]

  @@index([projectId, createdAt])
  @@index([projectId, action])
  @@index([projectId, countryCode])
  @@index([projectId, isHuman])
  @@index([sessionId])
  @@index([ipAddress])
  @@map("detections")
}

model ChallengeAttempt {
  id          String    @id @default(uuid())
  detectionId String    @map("detection_id")
  challengeId String    @map("challenge_id")
  issuedAt    DateTime  @default(now()) @map("issued_at")
  answeredAt  DateTime? @map("answered_at")
  success     Boolean
  timeToSolve Int?      @map("time_to_solve")

  detection Detection     @relation(fields: [detectionId], references: [id])
  challenge ChallengeBank @relation(fields: [challengeId], references: [id])

  @@index([detectionId])
  @@index([challengeId])
  @@map("challenge_attempts")
}

model ChallengeBank {
  id              String  @id @default(uuid())
  value           String  @unique
  successCount    Int     @default(0) @map("success_count")
  failCount       Int     @default(0) @map("fail_count")
  isActive        Boolean @default(true) @map("is_active")
  difficultyLevel Int     @default(0) @map("difficulty_level")

  attempts ChallengeAttempt[]

  @@map("challenge_bank")
}

// ─── Domain Monitoring ──────────────────────────────────────────

enum WatchDomainStatus {
  ACTIVE
  PAUSED
}

enum TldStrategy {
  SAME_TLD_ONLY
  ALLOWLIST
  MIXED
}

enum CandidateSource {
  GEMINI
  ALGO
  MANUAL
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model WatchDomain {
  id                  String            @id @default(uuid())
  tenantId            String            @map("tenant_id")
  userId              String            @map("user_id")
  domain              String
  label               String?
  status              WatchDomainStatus @default(ACTIVE)
  tldStrategy         TldStrategy       @default(MIXED)
  tldAllowlist        String[]          @default([]) @map("tld_allowlist")
  tldSuspicious       String[]          @default([]) @map("tld_suspicious")
  similarityThreshold Float?            @map("similarity_threshold")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  candidates CandidateDomain[]
  alerts     Alert[]

  @@unique([tenantId, domain])
  @@map("watch_domains")
}

model CandidateDomain {
  id              String          @id @default(uuid())
  watchDomainId   String          @map("watch_domain_id")
  domain          String
  tld             String
  source          CandidateSource
  similarityScore Float           @map("similarity_score")
  isActive        Boolean         @default(true) @map("is_active")
  rdapCheckedAt   DateTime?       @map("rdap_checked_at")
  rdapRegistered  Boolean?        @map("rdap_registered")
  rdapStatus      String[]        @default([]) @map("rdap_status")
  rdapRaw         Json?           @map("rdap_raw")

  watchDomain WatchDomain @relation(fields: [watchDomainId], references: [id], onDelete: Cascade)
  alerts      Alert[]

  @@unique([watchDomainId, domain])
  @@index([watchDomainId, isActive])
  @@map("candidate_domains")
}

model Alert {
  id                String        @id @default(uuid())
  tenantId          String        @map("tenant_id")
  userId            String        @map("user_id")
  watchDomainId     String        @map("watch_domain_id")
  candidateDomainId String        @map("candidate_domain_id")
  type              String        @default("SUSPICIOUS_DOMAIN")
  severity          AlertSeverity @default(INFO)
  message           String
  isRead            Boolean       @default(false) @map("is_read")
  createdAt         DateTime      @default(now()) @map("created_at")

  watchDomain     WatchDomain     @relation(fields: [watchDomainId], references: [id], onDelete: Cascade)
  candidateDomain CandidateDomain @relation(fields: [candidateDomainId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, isRead, createdAt])
  @@map("alerts")
}
